# Core provider selection
PROMPTPRO_PROVIDER=ollama
PROMPTPRO_MODEL=
PROMPTPRO_CONFIG_DIR=

# Runtime tuning
PROMPTPRO_TEMPERATURE=0.7
PROMPTPRO_TIMEOUT=300
PROMPTPRO_MAX_RETRIES=3
PROMPTPRO_NUM_VERSIONS=3
PROMPTPRO_MAX_HISTORY_ITEMS=100
PROMPTPRO_ENABLE_HISTORY=true
PROMPTPRO_AUTO_CLIPBOARD=true
PROMPTPRO_ENABLE_CLARIFY=true

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here
CLAUDE_BASE_URL=https://api.anthropic.com

# Custom OpenAI-compatible provider
CUSTOM_API_KEY=your-custom-api-key
CUSTOM_BASE_URL=https://your-api-endpoint.example/v1
